# ── PCP Pharmacy API ─────────────────────────────────────────────────────────
PCP_BASE_URL=https://pcpfulfillment.azurewebsites.net
PCP_PARTNER_ID=FEB64BC3-3EE1-4264-A699-59454C07A089

# ── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Klaviyo ──────────────────────────────────────────────────────────────────
KLAVIYO_API_KEY=your_klaviyo_private_api_key
KLAVIYO_LIST_ID=your_klaviyo_list_id

# ── Cloudflare (subdomain automation) ───────────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_zone_id
BASE_DOMAIN=yourdomain.com

# ── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
PLATFORM_NAME=RxVault
ADMIN_EMAIL=jp@yourdomain.com
